[Unit]
Description=StudyCal Flask backend
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/StudyCal/backend
Environment="PATH=/home/ubuntu/StudyCal/backend/venv/bin"
EnvironmentFile=/home/ubuntu/StudyCal/backend/.env
ExecStart=/home/ubuntu/StudyCal/backend/venv/bin/gunicorn -c gunicorn.conf.py run:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
