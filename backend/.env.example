# ── Flask ────────────────────────────────────────────────────
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1

# ── Security ─────────────────────────────────────────────────
# Change this to a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-long-random-secret

# ── Database ─────────────────────────────────────────────────
# SQLite (local dev) - leave as-is
DATABASE_URL=sqlite:///studycal.db

# PostgreSQL (production on Oracle Cloud) - fill in when deploying
# DATABASE_URL=postgresql://user:password@host:5432/studycal

# ── CORS ─────────────────────────────────────────────────────
# Frontend URL allowed to call the API
# Local dev:
FRONTEND_URL=http://localhost:5173
# Production (fill in after Vercel deploy):
# FRONTEND_URL=https://studycal.vercel.app
